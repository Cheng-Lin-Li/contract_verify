# =============================================================================
# contract_verify — environment configuration (v0.9.0)
# Copy to `.env` and adjust. NOTHING is hardcoded in source (Foundation Rule i):
# the OCR engine, LLM provider/model, thresholds, paths and log settings all
# come from here. Prompts live in backend/prompts/<locale>/PROMPTS.md.
# =============================================================================

APP_VERSION=0.9.0

# --- Deployment model --------------------------------------------------------
# contract_verify supports three deployment models:
#   on_prem -> every component on customer-controlled infrastructure (air-gap
#              capable). The default; nothing leaves the host.
#   cloud   -> every component runs in a cloud tenant (managed DB/blobs, cloud LLM).
#   hybrid  -> a split: keep sensitive data (DB, blobs, audit) on-prem while
#              running compute or public-facing pieces in the cloud — e.g. a
#              cloud LLM for accuracy with documents/audit staying local.
#
# This setting is declarative. `python -m cli.main doctor` reports where each
# component actually runs (inferred from the providers/URLs below) and warns
# when the real placement contradicts the declared mode (e.g. a cloud LLM under
# on_prem would move document content off the host).
DEPLOYMENT_MODE=on_prem

# --- LLM provider ------------------------------------------------------------
# Provider is swappable without code changes (Foundation Rule e).
#   fake   -> deterministic offline stand-in (no GPU/network) — used for tests
#             and the zero-dependency demo path.
#   ollama -> local models on the RTX 4070 Ti (DEFAULT for real runs).
#   anthropic -> cloud escape hatch (opt-in only).
#   openai / azure_openai -> backlog (raise NotImplementedError today).
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_EXTRACTION_MODEL=qwen3:14b-instruct-q4_K_M
LLM_VERIFY_MODEL=qwen3:14b-instruct-q4_K_M
EMBEDDING_MODEL=bge-m3
LLM_TEMPERATURE=0.1

# Cloud override (only read when LLM_PROVIDER=anthropic):
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_EXTRACTION_MODEL=claude-sonnet-4-6
# EMBEDDING_MODEL=voyage-3

# --- OCR ---------------------------------------------------------------------
# Swappable OCR engine (Foundation Rule f).
#   tesseract -> local, MVP default. paddleocr -> 3-month (tables/images).
#   paddleocr_vl / easyocr / google_vision -> backlog.
OCR_ENGINE=tesseract

# --- Storage / state ---------------------------------------------------------
# MVP uses SQLite + the local filesystem; the 3-month build swaps in Postgres,
# Qdrant and MinIO behind the same interfaces. A store counts as "local" when
# it is a sqlite:// URL or a filesystem path, and "cloud" otherwise (e.g. a
# remote postgresql:// host or an s3:// blob URL). In HYBRID deployments keep
# these local so sensitive documents and the audit trail stay on-prem.
DATABASE_URL=sqlite:///./contract_verify.db
BLOB_DIR=./var/blobs
AUDIT_LOG_PATH=./var/audit.jsonl

# Cloud / hybrid storage examples (uncomment for cloud or to move a store off-host):
# DATABASE_URL=postgresql+asyncpg://user:pass@db.internal:5432/contract_verify
# BLOB_DIR=s3://my-bucket/contract_verify/blobs
# AUDIT_LOG_PATH=s3://my-bucket/contract_verify/audit.jsonl

# --- S3 / MinIO (only used when BLOB_DIR is an s3:// URL) ---------------------
# Ships raw uploaded documents to an S3-compatible object store. Point at MinIO
# on-prem (set S3_ENDPOINT_URL) or AWS S3 (leave it blank). Requires boto3
# (`pip install boto3`). The bucket + key prefix come from the BLOB_DIR URL.
S3_ENDPOINT_URL=                 # e.g. http://localhost:9000 for MinIO; blank for AWS S3
S3_ACCESS_KEY=                   # e.g. MinIO root user / AWS access key id
S3_SECRET_KEY=                   # e.g. MinIO root password / AWS secret access key
S3_REGION=us-east-1

# Example HYBRID profile (cloud LLM + blobs in MinIO/S3; DB and audit stay local):
#   DEPLOYMENT_MODE=hybrid
#   LLM_PROVIDER=anthropic                        # compute in the cloud
#   ANTHROPIC_API_KEY=sk-ant-...
#   BLOB_DIR=s3://cv-bucket/blobs                 # documents -> object store
#   S3_ENDPOINT_URL=http://minio.internal:9000    # MinIO on the customer network
#   S3_ACCESS_KEY=...
#   S3_SECRET_KEY=...
#   DATABASE_URL=sqlite:///./contract_verify.db   # structured state stays local
#   AUDIT_LOG_PATH=./var/audit.jsonl              # audit stays local

# --- Scoring thresholds (tunable per deployment) -----------------------------
CS_HUMAN_REVIEW_THRESHOLD=0.70
CS_AUTO_CONFIRM_THRESHOLD=0.85
RISK_ATTORNEY_THRESHOLD=60

# --- Localization ------------------------------------------------------------
# MVP ships English; the 3-month build adds Japanese (SUPPORTED_LOCALES=en,ja).
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en
PROMPTS_DIR=backend/prompts

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=
LOG_FORMAT=json

# --- Security ----------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me
